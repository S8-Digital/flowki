# Flowki Mobile – Environment Variables
# Copy this file to .env and fill in the values.

# ── Backend API ──────────────────────────────────────────────────────────────
# Base URL of the Laravel backend (no trailing slash).
# For local dev with a physical device, use your machine's LAN IP instead of localhost.
EXPO_PUBLIC_API_URL=http://localhost:8000

# ── Firebase ─────────────────────────────────────────────────────────────────
# Copy these values from your Firebase console → Project Settings → General.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
