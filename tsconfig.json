{
    "compilerOptions": {
        "allowJs": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "isolatedModules": true,
        "target": "ESNext",
        "useDefineForClassFields": true,
        "lib": ["ESNext", "DOM"],
        "noEmit": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "types": ["vite/client", "./resources/js/types", "google.maps"],
        "paths": {
            "@/*": ["./resources/js/*"],
            "@flowki/shared": ["./shared/src"],
            "@flowki/shared/*": ["./shared/src/*"]
        }
    },
    "include": ["resources/js/**/*.ts", "resources/js/**/*.tsx", "resources/js/**/*.d.ts"]
}
